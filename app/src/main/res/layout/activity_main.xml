<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg"
    android:padding="16dp"
    tools:context=".MainActivity">

    <!-- App Header / Status -->
    <TextView
        android:id="@+id/tv_connect_status"
        android:text="@string/ununited"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:textColor="@color/app_text"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textAlignment="center"/>

    <!-- Beautiful Curved Interactive Touchpad Area -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/touchpad_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="8dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/app_surface"
        app:strokeColor="@color/app_accent"
        app:strokeWidth="1.5dp"
        app:cardElevation="6dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp">

            <ImageView
                android:id="@+id/iv_touchpad_icon"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_centerInParent="true"
                android:src="@drawable/ic_trackpad"
                android:layout_marginBottom="16dp"
                android:contentDescription="Touchpad Indicator" />

            <TextView
                android:id="@+id/tv_trackpad_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/iv_touchpad_icon"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="12dp"
                android:text="SWIPE HERE TO USE AS TOUCHPAD"
                android:textColor="@color/app_accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_trackpad_label"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="8dp"
                android:text="• Tap to Left-Click\n• Long-Press to Right-Click"
                android:textColor="@color/app_text"
                android:textSize="13sp"
                android:gravity="center"
                android:alpha="0.8"/>

        </RelativeLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:backgroundTint="@color/app_surface"
            android:textColor="@color/app_text"
            app:strokeColor="@color/app_accent"
            app:strokeWidth="1.2dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="Settings"/>

    </LinearLayout>

</LinearLayout>
